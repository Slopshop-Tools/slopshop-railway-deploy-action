{
  "name": "slopshop-railway-deploy-action",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "ncc build src/index.ts -o dist && tsx scripts/generate-schema.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "test": "vitest run",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{js,cjs,mjs,json,jsonc,md,css,yml}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@actions/core": "^1.11.1",
    "@actions/exec": "^1.1.1",
    "jsonc-parser": "^3.3.1",
    "zod": "^3"
  },
  "devDependencies": {
    "@eslint-community/eslint-plugin-eslint-comments": "^4.7.1",
    "@eslint/js": "^10.0.1",
    "@types/node": "^22",
    "@vercel/ncc": "^0.38.4",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "typescript-eslint": "^8.59.0",
    "vitest": "^3",
    "zod-to-json-schema": "^3.25.2"
  }
}
