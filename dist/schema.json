{
  "$ref": "#/definitions/RailwayDeployConfig",
  "definitions": {
    "RailwayDeployConfig": {
      "type": "object",
      "properties": {
        "version": {
          "type": "number"
        },
        "project": {
          "type": "object",
          "properties": {
            "name": {
              "type": "string",
              "minLength": 1
            }
          },
          "required": [
            "name"
          ],
          "additionalProperties": false
        },
        "databases": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": {
                "type": "string",
                "minLength": 1
              },
              "type": {
                "type": "string",
                "enum": [
                  "postgres",
                  "mysql",
                  "redis",
                  "mongo"
                ]
              },
              "railwayId": {
                "type": "string"
              },
              "railwayServiceName": {
                "type": "string"
              }
            },
            "required": [
              "name",
              "type"
            ],
            "additionalProperties": false
          },
          "default": []
        },
        "services": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": {
                "type": "string",
                "minLength": 1
              },
              "root": {
                "type": "string",
                "minLength": 1
              },
              "variables": {
                "type": "object",
                "additionalProperties": {
                  "type": "string"
                }
              }
            },
            "required": [
              "name",
              "root"
            ],
            "additionalProperties": false
          },
          "default": []
        }
      },
      "required": [
        "version",
        "project"
      ],
      "additionalProperties": false
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}